# ─────────────────────────────────────────────
# Imisi — Environment Variables
# Copy this file to apps/web/.env.local and fill in all values
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get these from: Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose client-side

# ── Anthropic (Claude AI) ─────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Recall.ai ─────────────────────────────────
# Get from: https://us-west-2.recall.ai/dashboard/apikeys
RECALLAI_API_KEY=your-recall-api-key

# ── Resend (email delivery) ────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=imisi@yourdomain.com   # Must be a verified Resend domain

# ── Google OAuth ───────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: https://your-project.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Microsoft / Azure OAuth ────────────────────
# Create at: https://portal.azure.com > Azure Active Directory > App registrations
# Callback URL: https://your-project.supabase.co/auth/v1/callback
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=common   # or your specific tenant ID

# ── Inngest (job queue) ────────────────────────
# Get from: https://app.inngest.com/settings
# Leave blank for local dev (uses Inngest Dev Server)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── App ────────────────────────────────────────
# Your public app URL (used in emails + webhook URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to authenticate Recall.ai webhook calls
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret
