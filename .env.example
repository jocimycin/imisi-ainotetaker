# ─────────────────────────────────────────────
# Imisi — Environment Variables
# Copy this file to apps/web/.env.local and fill in all values
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get these from: Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose client-side

# ── Anthropic (Claude AI) ─────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Recall.ai ─────────────────────────────────
# Get from: https://us-west-2.recall.ai/dashboard/apikeys
RECALLAI_API_KEY=your-recall-api-key

# ── Resend (email delivery) ────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=imisi@yourdomain.com   # Must be a verified Resend domain

# ── Google OAuth ───────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: https://your-app.vercel.app/api/auth/connect/callback?provider=google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Microsoft / Azure OAuth ────────────────────
# Create at: https://portal.azure.com > Azure Active Directory > App registrations
# Callback URL: https://your-app.vercel.app/api/auth/connect/callback?provider=microsoft
MICROSOFT_CLIENT_ID=your-azure-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret

# ── Notion OAuth ───────────────────────────────
# Create at: https://www.notion.so/my-integrations
# Callback URL: https://your-app.vercel.app/api/auth/connect/callback?provider=notion
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

# ── Asana OAuth ────────────────────────────────
# Create at: https://app.asana.com/0/my-apps
# Callback URL: https://your-app.vercel.app/api/auth/connect/callback?provider=asana
ASANA_CLIENT_ID=your-asana-client-id
ASANA_CLIENT_SECRET=your-asana-client-secret

# ── Jira / Atlassian OAuth ─────────────────────
# Create at: https://developer.atlassian.com/console/myapps/
# Callback URL: https://your-app.vercel.app/api/auth/connect/callback?provider=jira
JIRA_CLIENT_ID=your-atlassian-client-id
JIRA_CLIENT_SECRET=your-atlassian-client-secret

# ── Stripe ─────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # From: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_PRO_PRICE_ID=price_...     # Pro plan monthly price ID
STRIPE_TEAM_PRICE_ID=price_...    # Team plan monthly price ID

# ── Inngest (job queue) ────────────────────────
# Get from: https://app.inngest.com/settings
# Leave blank for local dev (uses Inngest Dev Server)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── App ────────────────────────────────────────
# Your public app URL (used in emails + webhook URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to authenticate Recall.ai webhook calls
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret
